# ─── Supabase (backend database) ───────────────────────────────────
# Get these from your Supabase project: Settings → API
#   - URL:           https://<project>.supabase.co
#   - service_role:  the `service_role` secret (FULL DB access — server-only!)
#                    NEVER expose this in client-side code.
#   - anon:          the `anon` public key (optional — only needed if you
#                    add client-side Supabase calls later)
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# ─── JWT signing secret ─────────────────────────────────────────────
# Issued by /api/login, verified by every authenticated endpoint.
# Must be at least 16 chars of random text. Generate one with:
#   openssl rand -hex 32
JWT_SECRET="GENERATE_A_LONG_RANDOM_SECRET_HERE_AT_LEAST_32_CHARS"

# ─── App URL (optional) ─────────────────────────────────────────────
# Used for self-referential links in emails (e.g. password reset).
# Defaults to the Vercel deployment URL if not set.
APP_URL="https://your-app.vercel.app"
